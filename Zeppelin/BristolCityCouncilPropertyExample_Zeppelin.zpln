      "status": "READY",
      "focus": true
    },
    {
      "text": "%livy2.pyspark\nimport matplotlib\nmatplotlib.use(\"Agg\")\nimport matplotlib.pyplot as plt\n\narea_df = spark.sql(\n    \"SELECT `Property Type`, SUM(`Site Area (Hectares)`) AS Total_Area \"\n    \"FROM BristolCouncilAssets GROUP BY `Property Type` \"\n    \"ORDER BY SUM(`Site Area (Hectares)`) DESC LIMIT 15\"\n).toPandas()\n\nplt.figure().set_figwidth(15)\nplt.title(\"Top land asset holdings by property type (Spark SQL)\")\nplt.xlabel(\"Property Type\")\nplt.xticks(rotation=90)\nplt.ylabel(\"Total area (Ha)\")\nplt.bar(area_df[\"Property Type\"], area_df[\"Total_Area\"])\nplt.tight_layout()\nshow(plt)",
