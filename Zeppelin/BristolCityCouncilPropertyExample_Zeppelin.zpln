      "settings": {
        "params": {},
        "forms": {}
      },
      "results": {},
      "apps": [],
      "runtimeInfos": {},
      "progressUpdateIntervalMs": 500,
      "jobName": "paragraph_1774118147572_93747068",
      "id": "paragraph_1774118147572_93747068",
      "dateCreated": "2025-10-28T14:18:59+0000",
      "status": "READY",
      "focus": true
    },
    {
      "text": "%livy2.pyspark\nimport matplotlib\nmatplotlib.use(\"Agg\")\nimport matplotlib.pyplot as plt\n\narea_df = (\n    df.groupBy(\"Property Type\")\n    .agg(F.sum(\"Site Area (Hectares)\").alias(\"Total_Area\"))\n    .orderBy(F.desc(\"Total_Area\"))\n    .limit(15)\n    .toPandas()\n)\n\nplt.figure().set_figwidth(15)\nplt.title(\"Top land asset holdings by property type (DataFrame API)\")\nplt.xlabel(\"Property Type\")\nplt.xticks(rotation=90)\nplt.ylabel(\"Total area (Ha)\")\nplt.bar(area_df[\"Property Type\"], area_df[\"Total_Area\"])\nplt.tight_layout()\nshow(plt)",
      "user": "anonymous",
      "progress": 0,
      "config": {
        "tableHide": false,
        "editorSetting": {
          "language": "python",
          "editOnDblClick": false,
          "completionKey": "TAB",
          "completionSupport": true
        },
        "colWidth": 12,
        "editorMode": "ace/mode/python",
        "fontSize": 9,
        "results": {},
        "enabled": true
      },
      "settings": {
        "params": {},
        "forms": {}
      },
      "results": {},
      "apps": [],
      "runtimeInfos": {},
      "progressUpdateIntervalMs": 500,
      "jobName": "paragraph_1774118147572_57787952",
      "id": "paragraph_1774118147572_57787952",
      "dateCreated": "2025-10-28T14:48:48+0000",
      "status": "READY"
    },
    {
