      "dateCreated": "2025-10-28T14:18:59+0000",
      "status": "READY",
      "focus": true
    },
    {
      "text": "%livy2.pyspark\ndistinct_types = df.select(\"Property Type\").distinct()\ndistinct_types.orderBy(\"Property Type\").show(truncate=False)\nprint(f\"Unique property types (DataFrame API): {distinct_types.count()}\")",
